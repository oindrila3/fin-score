# ============================================================
# FIN-Score Environment Variables
# ============================================================


# ── Environment ───────────────────────────────────────────
ENVIRONMENT=development
# Options: development, staging, production

# ── API Settings ──────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=true

# ── Model Settings ────────────────────────────────────────
MODEL_DIR=models
DATA_DIR=data

# ── Database ──────────────────────────────────────────────
DB_PATH = models/finscore_monitoring.db
# Production: postgresql://user:password@host:5432/finscore
# Snowflake:  snowflake://user:password@account/database

# ── Monitoring ────────────────────────────────────────────
ALERT_HOT_RATE_MAX=0.5
ALERT_HOT_RATE_MIN=0.1
ALERT_AUC_THRESHOLD=0.80
ALERT_TREND_DELTA_MAX=0.05

# ── Kaggle (for data download) ────────────────────────────
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key